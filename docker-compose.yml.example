services:
  scan-gateway:
    image: scan-gateway:latest
    container_name: scan-gateway
    restart: unless-stopped

    # ┌─────────────────────────────────────────────────────────────┐
    # │                   SETTINGS TO CONFIGURE                     │
    # └─────────────────────────────────────────────────────────────┘
    environment:
      # SMB credentials (used by scanners to connect)
      SMB_USER: "scanner"
      SMB_PASSWORD: "changeme"

      # Polling interval in seconds (how often to check for new files)
      POLL_INTERVAL: "3"

      # Destinations format: smb_folder|webdav_url|webdav_user|webdav_password
      # - smb_folder   : name of the SMB share (e.g. "office" → \\IP\office)
      # - webdav_url   : full WebDAV URL of the destination folder
      # - webdav_user  : WebDAV username
      # - webdav_password : WebDAV password (use an app password for Nextcloud!)
      #
      # Multiple destinations: separate with a comma
      # Example with Nextcloud:
      #   webdav_url = https://nextcloud.example.com/remote.php/dav/files/USERNAME/Scans/Office/
      DESTINATIONS: "office|https://nextcloud.example.com/remote.php/dav/files/admin/Scans/Office/|admin|app-password"

    # ┌─────────────────────────────────────────────────────────────┐
    # │  NETWORK — give the container its own IP on your LAN        │
    # │  Avoids port 445 conflict with the host (e.g. TrueNAS SMB)  │
    # └─────────────────────────────────────────────────────────────┘
    networks:
      scan-gateway-net:
        ipv4_address: 192.168.1.250   # ← choose a free IP on your network

# The macvlan network must be created manually before starting:
#
#   docker network create -d macvlan \
#     --subnet=192.168.1.0/24 \
#     --gateway=192.168.1.1 \
#     -o parent=br0 \
#     scan-gateway-net
#
# Replace subnet, gateway and parent interface to match your network.

networks:
  scan-gateway-net:
    external: true
