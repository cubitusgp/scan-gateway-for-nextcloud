services:
  scan-gateway:
    image: scan-gateway:latest
    container_name: scan-gateway
    restart: unless-stopped

    # ┌─────────────────────────────────────────────────────────────┐
    # │                   SETTINGS TO CONFIGURE                     │
    # └─────────────────────────────────────────────────────────────┘
    environment:
      # Admin UI credentials
      ADMIN_USER: "admin"
      ADMIN_PASSWORD: "changeme"
      ADMIN_SECRET: "change-this-random-secret"

      # Polling interval in seconds
      POLL_INTERVAL: "3"

      # Initial SMB credentials (can be changed later in the admin UI)
      SMB_USER: "scanner"
      SMB_PASSWORD: "changeme"

      # Initial destinations (can be managed later in the admin UI)
      # Format: smb_folder|webdav_url|webdav_user|webdav_password
      # Leave empty to configure everything from the admin UI
      DESTINATIONS: "office|https://nextcloud.example.com/remote.php/dav/files/admin/Scans/Office/|admin|app-password"

    volumes:
      # Persistent config (survives container restarts)
      - /mnt/StoRaid/scan-gateway/config:/config

    ports:
      # Admin UI — only needed if NOT using macvlan
      - "4380:4380"

    networks:
      scan-gateway-net:
        ipv4_address: 192.168.1.250   # ← choose a free IP on your network

# The macvlan network must be created manually before starting:
#
#   docker network create -d macvlan \
#     --subnet=192.168.1.0/24 \
#     --gateway=192.168.1.1 \
#     -o parent=br0 \
#     scan-gateway-net
#
# Replace subnet, gateway and parent interface to match your network.

networks:
  scan-gateway-net:
    external: true
